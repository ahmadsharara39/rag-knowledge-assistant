# Copy to .env and fill in as needed. Leave blank to run fully offline.

# --- Providers (offline defaults) ---
LLM_PROVIDER=extractive          # openai | anthropic | extractive
EMBEDDING_PROVIDER=hash          # openai | huggingface | hash
VECTOR_STORE=faiss               # faiss | pinecone

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Hugging Face (local embeddings) ---
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Pinecone ---
PINECONE_API_KEY=
PINECONE_INDEX=rag-knowledge

# --- Retrieval / chunking ---
EMBEDDING_DIM=384
CHUNK_SIZE=800
CHUNK_OVERLAP=120
DEFAULT_TOP_K=4

# --- Security ---
API_KEYS=dev-local-key
RATE_LIMIT_PER_MINUTE=60

# --- Storage ---
DATA_DIR=storage
